<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background_global"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:padding="4dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="个人资料"
            android:textColor="@color/color_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:background="@drawable/bg_profile_card"
        android:elevation="2dp"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/itemEditAvatar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground">
            <TextView
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="头像" android:textColor="@color/color_text_primary" android:textSize="16sp" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivEditAvatar"
                android:layout_width="40dp" android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_logo_wordup" android:scaleType="centerCrop"
                android:background="@color/color_input_inactive"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.App.CircleImageView" />
            <ImageView
                android:layout_width="16dp" android:layout_height="16dp"
                android:src="@drawable/ic_arrow_right" app:tint="@color/color_input_inactive"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginHorizontal="20dp" android:background="#F0EBE1" />

        <LinearLayout
            android:id="@+id/itemEditNickname"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground">
            <TextView
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="昵称" android:textColor="@color/color_text_primary" android:textSize="16sp" />
            <TextView
                android:id="@+id/tvEditNickname"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginEnd="8dp" android:text="WordUp 用户" android:textColor="@color/color_input_inactive" />
            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_arrow_right" app:tint="@color/color_input_inactive"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginHorizontal="20dp" android:background="#F0EBE1" />

        <LinearLayout
            android:id="@+id/itemEditGender"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground">
            <TextView
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="性别" android:textColor="@color/color_text_primary" android:textSize="16sp" />
            <TextView
                android:id="@+id/tvEditGender"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginEnd="8dp" android:text="保密" android:textColor="@color/color_input_inactive" />
            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_arrow_right" app:tint="@color/color_input_inactive"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginHorizontal="20dp" android:background="#F0EBE1" />

        <LinearLayout
            android:id="@+id/itemEditSchool"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground">
            <TextView
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="学校" android:textColor="@color/color_text_primary" android:textSize="16sp" />
            <TextView
                android:id="@+id/tvEditSchool"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginEnd="8dp" android:text="未设置" android:textColor="@color/color_input_inactive" />
            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_arrow_right" app:tint="@color/color_input_inactive"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginHorizontal="20dp" android:background="#F0EBE1" />

        <LinearLayout
            android:id="@+id/itemEditGrade"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground">
            <TextView
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="年级" android:textColor="@color/color_text_primary" android:textSize="16sp" />
            <TextView
                android:id="@+id/tvEditGrade"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginEnd="8dp" android:text="未设置" android:textColor="@color/color_input_inactive" />
            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_arrow_right" app:tint="@color/color_input_inactive"/>
        </LinearLayout>

    </LinearLayout>
</LinearLayout>